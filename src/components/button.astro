---
const { href = "#", stylingclasses = "" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "bg-cta hover:bg-cta-hover text-neutral-black font-abril text-[16px] md:text-[17px] lg:text-[18px] px-6 py-3 inline-block transition duration-300",
    "shadow-[0_4px_10px_rgba(0,0,0,0.25)]",
    stylingclasses
  ]}
>
  <slot />
</a>